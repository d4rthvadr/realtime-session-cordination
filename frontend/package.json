{
  "name": "realtime-session-frontend",
  "private": true,
  "version": "0.1.0",
  "engines": {
    "node": ">=22.13.0 <23 || >=24.0.0",
    "npm": ">=10"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:user": "npm run dev -w @realtime/user",
    "dev:admin": "npm run dev -w @realtime/admin",
    "build": "npm run build -ws --if-present",
    "lint": "npm run lint -ws --if-present",
    "test": "npm run test -ws --if-present"
  }
}
